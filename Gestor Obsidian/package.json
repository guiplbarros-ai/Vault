{
  "name": "obsidian-manager",
  "version": "1.1.0",
  "description": "CLI para gerenciar notas no Obsidian, tarefas no Todoist, Notion, Google Calendar e Gmail",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "obsidian-manager": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:cli": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "dev:server": "node --import tsx src/server.ts",
    "start:server": "node dist/server.js",
    "mcp:todoist": "node --import tsx src/mcp/todoist.server.ts",
    "note": "node --import tsx src/index.ts note",
    "calendar": "node --import tsx src/index.ts calendar",
    "gmail": "node --import tsx src/index.ts gmail",
    "google:auth": "node --import tsx src/index.ts google auth",
    "google:status": "node --import tsx src/index.ts google status"
  },
  "keywords": [
    "obsidian",
    "notes",
    "cli",
    "second-brain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.73.0"
  },
  "overrides": {
    "node-telegram-bot-api": {
      "request": "npm:@cypress/request@^3.0.0"
    }
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
