# Caminho absoluto para o vault Obsidian
# Copie este arquivo para .env e configure o caminho do seu vault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Token da API do Todoist
# Obtenha em: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=seu_token_aqui

# Notion (recomendado): integrado via MCP no Cursor (não precisa de token aqui)

# Telegram Bot
# Crie um bot em @BotFather e coloque o token aqui
TELEGRAM_BOT_TOKEN=seu_token_aqui

# (Opcional) IDs de usuários autorizados, separados por vírgula
# Use /id no bot para descobrir seu ID
TELEGRAM_AUTHORIZED_USERS=

# (Opcional) IDs de chats que recebem resumo diário automaticamente
# Descubra seu chat ID usando /id no bot
DAILY_DIGEST_CHATS=

# OpenAI API Key (para classificação inteligente no Telegram)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_aqui

# Notion API Key (opcional - para automação/terminal/Telegram sem MCP)
# Crie uma integração em: https://www.notion.so/my-integrations
# Depois conecte a integração às páginas que quer acessar
NOTION_API_KEY=sua_chave_aqui

# ============================================
# GOOGLE CALENDAR & GMAIL
# ============================================
# Para usar o Google Calendar e Gmail, você precisa criar credenciais OAuth2:
#
# 1. Acesse: https://console.cloud.google.com/apis/credentials
# 2. Crie um novo projeto (ou use um existente)
# 3. Ative as APIs: Google Calendar API e Gmail API
#    - https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
#    - https://console.cloud.google.com/apis/library/gmail.googleapis.com
# 4. Configure a tela de consentimento OAuth:
#    - https://console.cloud.google.com/apis/credentials/consent
#    - Escolha "Externo" se for uso pessoal
#    - Adicione seu email como usuário de teste
# 5. Crie credenciais OAuth 2.0:
#    - Tipo: Aplicativo de desktop (ou Web application)
#    - Se web: adicione http://localhost:3000/oauth2callback como URI de redirecionamento autorizado
# 6. Copie o Client ID e Client Secret abaixo

GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# URI de redirecionamento (padrão: http://localhost:3000/oauth2callback)
# Mude apenas se configurou diferente no Google Console
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

