# ============================================
# ATLAS - Monitor de Passagens Aereas
# ============================================

# Telegram Bot
# Crie um bot em @BotFather e coloque o token aqui
TELEGRAM_BOT_TOKEN=seu_token_aqui

# (Opcional) Secret para validar webhooks do Telegram
TELEGRAM_WEBHOOK_SECRET=

# (Opcional) IDs de usuarios autorizados, separados por virgula
# Use /id no bot para descobrir seu ID
TELEGRAM_AUTHORIZED_USERS=

# ============================================
# SUPABASE (PostgreSQL)
# ============================================
# URL do projeto (Settings -> API -> Project URL)
SUPABASE_URL=

# Service role key (Settings -> API -> Project API keys -> service_role)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# PROVEDORES DE BUSCA DE VOOS
# ============================================

# Kiwi Tequila (GRATUITO - principal)
# Obtenha em: https://tequila.kiwi.com/
KIWI_API_KEY=

# SerpAPI (Google Flights) - $10/mes 1000 calls
# Obtenha em: https://serpapi.com/
SERPAPI_API_KEY=

# Limite mensal de calls SerpAPI (padrao: 100 = ~$1/mes)
# Bloqueia automaticamente quando atingido e usa Kiwi como fallback
ATLAS_SERPAPI_MONTHLY_LIMIT=100

# Amadeus (GRATUITO - 500 calls/mes)
# Obtenha em: https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ============================================
# CONFIGURACOES
# ============================================

# Timezone para crons e formatacao de datas
ATLAS_TIMEZONE=America/Sao_Paulo

# Threshold padrao para alertas (% de queda)
ATLAS_ALERT_DROP_PERCENT=15

# Horarios dos crons de busca (padrao: 08:00 e 20:00)
ATLAS_SEARCH_CRONS=0 8 * * *,0 20 * * *

# Horario do digest diario (padrao: 08:30)
ATLAS_DIGEST_CRON=30 8 * * *

# Debug mode
DEBUG=

# ============================================
# FLY.IO (Deploy)
# ============================================
# Porta do servidor HTTP
PORT=3000
