# OBS: este projeto não usa mais Obsidian local como fonte/sink.
# O “cérebro” é Supabase (source of truth) + Supermemory (retrieval).

# Token da API do Todoist
# Obtenha em: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=seu_token_aqui

# Notion (recomendado): integrado via MCP no Cursor (não precisa de token aqui)

# Telegram Bot
# Crie um bot em @BotFather e coloque o token aqui
TELEGRAM_BOT_TOKEN=seu_token_aqui

# (Opcional) IDs de usuários autorizados, separados por vírgula
# Use /id no bot para descobrir seu ID
TELEGRAM_AUTHORIZED_USERS=

# (Opcional) Pasta temporária para downloads de mídia (áudio/foto/vídeo) do Telegram
# Padrão: ./tmp/telegram-media
TELEGRAM_MEDIA_TMP_DIR=

# (Opcional) IDs de chats que recebem resumo diário automaticamente
# Descubra seu chat ID usando /id no bot
DAILY_DIGEST_CHATS=

# ============================================
# MEMORY REFRESH (Supabase -> Supermemory + ingest de fontes)
# ============================================
# Ativa/desativa o refresh automático (padrão: 1)
MEMORY_REFRESH_ENABLED=1
# Timezone dos crons
MEMORY_REFRESH_TIMEZONE=America/Sao_Paulo
# Refresh COMPLETO (padrão: 02:00 e 14:30)
MEMORY_REFRESH_FULL_CRONS=0 2 * * *,30 14 * * *
# Refresh LEVE (meio do intervalo; padrão: 08:15 e 16:45)
MEMORY_REFRESH_LIGHT_CRONS=15 8 * * *,45 16 * * *
# Chats que recebem "memory refresh ✅" quando rodar via cron (IDs separados por vírgula)
MEMORY_REFRESH_NOTIFY_CHATS=

# ============================================
# TEMPO (Tomorrow.io)
# ============================================
# API key: crie em https://www.tomorrow.io/
TOMORROW_API_KEY=sua_chave_aqui
# Localização padrão do forecast (aceita "lat,lon" ou texto)
TOMORROW_LOCATION=-23.5505,-46.6333
# metric | imperial
TOMORROW_UNITS=metric

# OpenAI API Key (para classificação inteligente no Telegram)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_aqui

# (Opcional) Custos OpenAI para estimativa no report semanal.
# Valores em USD por 1M tokens. Se não preencher, o bot mostra tokens mas não calcula USD.
CORTEX_OPENAI_USD_PER_1M_INPUT=
CORTEX_OPENAI_USD_PER_1M_OUTPUT=

# (Opcional) Estimativa simples do custo do Fly (USD/dia) para aparecer no report semanal.
# (Integração real com billing do Fly fica para depois.)
CORTEX_FLY_USD_PER_DAY=

# ============================================
# SUPABASE (cloud-first)
# ============================================
# URL do projeto (Settings → API → Project URL)
SUPABASE_URL=
# Service role key (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# (Opcional) Bucket para guardar mídia recebida do Telegram (áudio/foto/vídeo)
# Padrão: cortex-media (bucket privado; o bot gera signed URL de 7 dias na nota)
SUPABASE_MEDIA_BUCKET=

# Workspace padrão quando o chat ainda não escolheu /contexto
# Valores: pessoal | freelaw
CORTEX_DEFAULT_WORKSPACE=pessoal

# ============================================
# GOOGLE OAUTH (Calendar/Gmail/Drive/Sheets)
# ============================================
# IMPORTANTE:
# - Para uso via Telegram/Fly, o redirect URI NÃO pode ser localhost.
# - No Google Cloud Console (OAuth client), adicione o mesmo URI em "Authorized redirect URIs".
# Exemplos:
# - produção (Fly): https://<seu-app>.fly.dev/oauth2callback
# - local/CLI:      http://localhost:3000/oauth2callback
GOOGLE_REDIRECT_URI=

# Segredo para assinar o parâmetro state do OAuth (recomendado no Fly).
# Se vazio, o server tenta reutilizar TELEGRAM_WEBHOOK_SECRET (se houver), mas é melhor definir explicitamente.
CORTEX_OAUTH_STATE_SECRET=

# Para usar o MCP Supabase (SQL direto no Cursor)
# Postgres connection string (Settings → Database → Connection string)
SUPABASE_DB_URL=

# Notion API Key (opcional - para automação/terminal/refresh)
# Crie uma integração em: https://www.notion.so/my-integrations
# Depois conecte a integração às páginas que quer acessar
NOTION_API_KEY=sua_chave_aqui

# Opcional (recomendado): duas integrações separadas (duas contas / workspaces)
# - PESSOAL (guiplbarros)
NOTION_API_KEY_PESSOAL=
# - FREELAW
NOTION_API_KEY_FREELAW=

# Databases do Notion a ingerir (refresh completo) por workspace
# Separe por vírgula. Ex: NOTION_REFRESH_DATABASE_IDS_PESSOAL=aaaaaaaa...,bbbbbbbb...
NOTION_REFRESH_DATABASE_IDS_PESSOAL=
NOTION_REFRESH_DATABASE_IDS_FREELAW=

# ============================================
# SUPERMEMORY (cloud memory)
# ============================================
# API key do Supermemory
SUPERMEMORY_API_KEY=
# (Opcional) Base URL da API (padrão: https://api.supermemory.ai)
SUPERMEMORY_BASE_URL=
# (Opcional) Timeout em ms (padrão: 8000)
SUPERMEMORY_TIMEOUT_MS=8000
# (Opcional) Se 1, o Brain tenta buscar memórias automaticamente antes do LLM (padrão: 1)
SUPERMEMORY_AUTO_RETRIEVE=1
# (Opcional) Limite de resultados no auto-retrieve (padrão: 6; máx: 12)
SUPERMEMORY_AUTO_RETRIEVE_LIMIT=6
# (Opcional) Se 1, o Brain salva automaticamente mensagens do tipo "lembre que..." (padrão: 1)
SUPERMEMORY_AUTO_INGEST=1
# (Opcional) Logs de debug para retrieve/ingest (padrão: 0)
SUPERMEMORY_DEBUG=0
# (Opcional) Indexar notas do Supabase no Supermemory (resumo + id). Padrão: 1
SUPERMEMORY_INDEX_SUPABASE_NOTES=1
# (Opcional) Tamanho do excerpt (em chars) enviado ao Supermemory por nota. Padrão: 1400 (limite: 5000)
SUPERMEMORY_INDEX_NOTE_EXCERPT_CHARS=1400

# ============================================
# POLYMARKET (prediction markets)
# ============================================
# API pública (Gamma API) — não requer chave.
# Base URL padrão: https://gamma-api.polymarket.com
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
# Timeout HTTP em ms (padrão: 8000)
POLYMARKET_TIMEOUT_MS=8000

# ============================================
# POLICY LAYER (RAG inteligente por conversa)
# ============================================
# Se 1, roda a camada de policy antes do Brain (padrão: 1)
CORTEX_POLICY_ENABLED=1
# Se 1, usa um classificador via LLM (padrão: 1). Se 0, usa só heurísticas.
CORTEX_POLICY_USE_LLM=1
# (Opcional) Modelo para policy (padrão: CORTEX_MODEL_FAST ou CORTEX_MODEL)
CORTEX_POLICY_MODEL=
# (Opcional) Debug de falhas na policy (padrão: 0)
CORTEX_POLICY_DEBUG=0

# ============================================
# NEWS / RSS / HACKER NEWS (Digest)
# ============================================
# Se 1, inclui notícias no /resumo (padrão: 1)
NEWS_ENABLED=1
# Timeout HTTP em ms (padrão: 8000)
NEWS_TIMEOUT_MS=8000

# Feeds RSS (se vazio, usa defaults baseados em Google News RSS)
NEWS_RSS_GENERAL_FEEDS=
NEWS_RSS_FINANCE_FEEDS=
NEWS_RSS_SPORTS_FEEDS=

# “Pouca política”: palavras para EXCLUIR (aplicado em general/finance quando NEWS_ALLOW_POLITICS=0)
NEWS_EXCLUDE_KEYWORDS=bolsonaro,lula,congresso,senado,câmara,stf,eleição,eleições
# Se 1, não filtra política (padrão: 0)
NEWS_ALLOW_POLITICS=0

# Se preencher, vira filtro “must match” por tópico (opcional)
NEWS_INCLUDE_KEYWORDS_GENERAL=
NEWS_INCLUDE_KEYWORDS_FINANCE=
NEWS_INCLUDE_KEYWORDS_SPORTS=atlético mineiro,galo,pittsburgh steelers,steelers

# Hacker News via Algolia (front page)
HN_ENABLED=1

# ============================================
# GOOGLE CALENDAR & GMAIL
# ============================================
# Para usar o Google Calendar e Gmail, você precisa criar credenciais OAuth2:
#
# 1. Acesse: https://console.cloud.google.com/apis/credentials
# 2. Crie um novo projeto (ou use um existente)
# 3. Ative as APIs: Google Calendar API e Gmail API
#    - https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
#    - https://console.cloud.google.com/apis/library/gmail.googleapis.com
# 4. Configure a tela de consentimento OAuth:
#    - https://console.cloud.google.com/apis/credentials/consent
#    - Escolha "Externo" se for uso pessoal
#    - Adicione seu email como usuário de teste
# 5. Crie credenciais OAuth 2.0:
#    - Tipo: Aplicativo de desktop (ou Web application)
#    - Se web: adicione http://localhost:3000/oauth2callback como URI de redirecionamento autorizado
# 6. Copie o Client ID e Client Secret abaixo

GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# URI de redirecionamento
# - Dev local (CLI): http://localhost:3000/oauth2callback
# - Produção (Fly): https://cortex-app.fly.dev/oauth2callback (ou seu domínio)
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Assinatura do parâmetro "state" do OAuth (evita sequestro do callback)
# Em produção, defina um segredo longo (pode reutilizar o TELEGRAM_WEBHOOK_SECRET, mas é melhor separar)
CORTEX_OAUTH_STATE_SECRET=

# (Opcional) Caminho do arquivo de tokens do Google.
# Útil para segregar tokens por conta/projeto (ex.: pessoal vs profissional).
# Se não definido, o app usa um arquivo diferente POR client_id em:
# ~/.obsidian-manager/google-tokens.<client_id>.json
# GOOGLE_TOKENS_PATH=/Users/seuusuario/.obsidian-manager/google-tokens.pessoal.json

