{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--no-sandbox",
        "--caps", "vision",
        "--viewport-size", "1280x720",
        "--isolated"
      ],
      "env": { "DISPLAY": "" }
    }
  }
}
