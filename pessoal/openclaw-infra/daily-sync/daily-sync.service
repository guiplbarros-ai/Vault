[Unit]
Description=OpenClaw Daily Sync — reports project status to Discord
After=network.target claude-relay.service

[Service]
Type=oneshot
ExecStart=/usr/bin/node /home/guipl/.openclaw/daily-sync/daily-sync.js
EnvironmentFile=/home/guipl/.openclaw/.env
Environment=RELAY_URL=http://localhost:18790
Environment=PATH=/home/guipl/.bun/bin:/home/guipl/.openclaw/tools:/usr/local/bin:/usr/bin:/bin
TimeoutStartSec=900
