{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },

  "models": {
    "providers": {
      "claude-relay": {
        "baseUrl": "http://127.0.0.1:18790/v1",
        "apiKey": "relay-local",
        "api": "openai-completions",
        "models": [
          { "id": "relay/backstage", "name": "Relay Backstage (Sonnet via CLI)", "contextWindow": 200000, "maxTokens": 16384, "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 } },
          { "id": "relay/data",      "name": "Relay Data (Opus via CLI)",      "contextWindow": 200000, "maxTokens": 16384, "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 } },
          { "id": "relay/review",    "name": "Relay Review (Sonnet via CLI)",  "contextWindow": 200000, "maxTokens": 16384, "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 } },
          { "id": "relay/ops",       "name": "Relay Ops (Haiku via CLI)",      "contextWindow": 200000, "maxTokens": 16384, "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 } },
          { "id": "relay/pessoal",   "name": "Relay Pessoal (Sonnet via CLI)", "contextWindow": 200000, "maxTokens": 16384, "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 } }
        ]
      },
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      },
      "openai": {
        "apiKey": "${OPENAI_API_KEY}"
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "relay/backstage"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "backstage",
        "workspace": "~/.openclaw/workspace-backstage",
        "model": { "primary": "relay/backstage" },
        "tools": {
          "allow": ["exec", "read", "write", "edit", "web_browse", "memory"],
          "deny": []
        }
      },
      {
        "id": "data",
        "workspace": "~/.openclaw/workspace-data",
        "model": { "primary": "relay/data" },
        "tools": {
          "allow": ["exec", "read", "write", "edit", "memory"],
          "deny": ["web_browse"]
        }
      },
      {
        "id": "review",
        "workspace": "~/.openclaw/workspace-review",
        "model": { "primary": "relay/review" },
        "tools": {
          "allow": ["exec", "read", "memory", "web_browse"],
          "deny": ["write", "edit"]
        }
      },
      {
        "id": "ops",
        "workspace": "~/.openclaw/workspace-ops",
        "model": { "primary": "relay/ops" },
        "tools": {
          "allow": ["exec", "read", "memory"],
          "deny": ["write", "edit"]
        }
      },
      {
        "id": "pessoal",
        "workspace": "~/.openclaw/workspace-pessoal",
        "model": { "primary": "relay/pessoal" },
        "tools": {
          "allow": ["exec", "read", "write", "edit", "web_browse", "memory"],
          "deny": []
        }
      }
    ]
  },

  "bindings": [
    {
      "agentId": "backstage",
      "match": { "channel": "discord", "accountId": "backstage" }
    },
    {
      "agentId": "data",
      "match": { "channel": "discord", "accountId": "data" }
    },
    {
      "agentId": "review",
      "match": { "channel": "discord", "accountId": "review" }
    },
    {
      "agentId": "ops",
      "match": { "channel": "discord", "accountId": "ops" }
    },
    {
      "agentId": "pessoal",
      "match": { "channel": "discord", "accountId": "pessoal" }
    }
  ],

  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "streamMode": "partial",
      "draftChunk": {
        "minChars": 200,
        "maxChars": 800,
        "breakPreference": "paragraph"
      },
      "accounts": {
        "backstage": {
          "token": "${DISCORD_BOT_BACKSTAGE}",
          "guilds": {
            "1474803246022266911": {
              "requireMention": false,
              "users": ["703006877700587622"],
              "channels": {
                "backstage": { "allow": true },
                "financeiro": { "allow": true }
              }
            }
          }
        },
        "data": {
          "token": "${DISCORD_BOT_DATA}",
          "guilds": {
            "1474803246022266911": {
              "requireMention": false,
              "users": ["703006877700587622"],
              "channels": {
                "data": { "allow": true },
                "schemas": { "allow": true }
              }
            }
          }
        },
        "review": {
          "token": "${DISCORD_BOT_REVIEW}",
          "guilds": {
            "1474803246022266911": {
              "requireMention": false,
              "users": ["703006877700587622"],
              "channels": {
                "review": { "allow": true }
              }
            }
          }
        },
        "ops": {
          "token": "${DISCORD_BOT_OPS}",
          "guilds": {
            "1474803246022266911": {
              "requireMention": false,
              "users": ["703006877700587622"],
              "channels": {
                "ops": { "allow": true },
                "status": { "allow": true }
              }
            }
          }
        },
        "pessoal": {
          "token": "${DISCORD_BOT_PESSOAL}",
          "guilds": {
            "1474803246022266911": {
              "requireMention": false,
              "users": ["703006877700587622"],
              "channels": {
                "cortex-app": { "allow": true },
                "cortex-cash": { "allow": true },
                "atlas": { "allow": true }
              }
            }
          }
        }
      },
      "execApprovals": {
        "enabled": true,
        "approvers": ["703006877700587622"],
        "target": "channel"
      }
    }
  },

  "skills": {
    "load": {
      "extraDirs": ["~/.openclaw/skills-freelaw"]
    }
  }
}
